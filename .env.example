# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- Edge Function secrets (server-side only, NEVER shipped to the browser) ---
# Set for real via: supabase secrets set KEY=value
GOOGLE_PLACES_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Client-safe (Supabase project URL + anon key) ---
# These end up inline in the frontend JS, which is fine: the anon key only
# grants the public read policy on `spots`. Kept here for local reference.
SUPABASE_URL=
SUPABASE_ANON_KEY=
